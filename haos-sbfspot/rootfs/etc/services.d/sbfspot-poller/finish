#!/usr/bin/with-contenv bash
# finish script for sbfspot-poller. On normal exit (addon stop) don't restart.
# On crash (exit != 0): log and restart after 10s to avoid tight respawn loop.
EXIT_CODE=$1
if [[ "${EXIT_CODE}" == "0" ]]; then
    exit 0
fi
echo "[sbfspot-poller/finish] crashed with exit=${EXIT_CODE}; pausing 10s before respawn"
sleep 10
exit 0
